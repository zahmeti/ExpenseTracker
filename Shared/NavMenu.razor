@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="app-sidebar">
    <div class="sidebar-brand">
        <span class="brand-icon oi oi-dollar"></span>
        <div>
            <strong>Expense Tracker</strong>
            <small>Spend smarter</small>
        </div>
    </div>

    <div class="sidebar-section-label">Menu</div>

    <ul class="nav flex-column sidebar-nav">
        <li class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon oi oi-home"></span>
                <span>Home</span>
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="expenses">
                <span class="nav-icon oi oi-dollar"></span>
                <span>Expenses</span>
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="reports">
                <span class="nav-icon oi oi-bar-chart"></span>
                <span>Reports</span>
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="budgets">
                <span class="nav-icon oi oi-task"></span>
                <span>Budgets</span>
            </NavLink>
        </li>
    </ul>

    <!-- Sidebar Footer -->
    <AuthorizeView>
        <Authorized>
        <div class="app-sidebar-footer mt-auto">
            <div class="account-card">
                <div class="account-avatar">@GetUserInitial()</div>
                <div class="account-meta">
                    <span>Signed in as</span>
                    <strong>@userEmail</strong>
                </div>
            </div>
            <NavLink class="nav-link logout-link" href="/authentication/logout">
                <span class="nav-icon oi oi-account-logout"></span>
                <span>Logout</span>
            </NavLink>
        </div>
    </Authorized>
        <NotAuthorized>
            <div class="app-sidebar-footer mt-auto">
                <NavLink class="nav-link" href="/authentication/login">
                    <span class="nav-icon oi oi-account-login"></span>
                    <span>Login</span>
                </NavLink>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private string? userEmail;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            userEmail = user.Identity.Name;
        }
    }

    private string GetUserInitial()
    {
        return string.IsNullOrWhiteSpace(userEmail)
            ? "U"
            : userEmail.Trim()[0].ToString().ToUpperInvariant();
    }

    private async Task HandleLogout()
    {
        var context = HttpContextAccessor.HttpContext;
        if (context != null)
        {
            // ✅ Clear Identity cookie directly
            context.Response.Cookies.Delete(".AspNetCore.Identity.Application");

            // ✅ Also call SignOutAsync for safety
            await context.SignOutAsync(IdentityConstants.ApplicationScheme);
        }

        // ✅ Show toast/snackbar before redirect
        await JSRuntime.InvokeVoidAsync("showLogoutToast");

        // ✅ Redirect to Login/Register page
        Navigation.NavigateTo("/authentication/login", forceLoad: true);
    }
}
