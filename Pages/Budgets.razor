@page "/budgets"
@using ExpenseTracker.Models
@using ExpenseTracker.Services
@using System.Security.Claims
@inject ExpenseService ExpenseService
@inject CategoryService CategoryService
@inject BudgetService BudgetService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime

<h3 class="gradient-title">Budgets</h3>

<!-- Add New Budget -->
<div class="glass-card p-4 mb-4">
    <h5 class="section-title">Add Budget</h5>
    <div class="row g-3">
        <!-- Category: select OR type -->
        <div class="col-md-4">
            <select class="form-select stylish-input" @bind="newBudget.Category">
                <option value="">-- Select Category --</option>
                @foreach (var category in categories)
                {
                    <option value="@category.Name">@category.Name</option>
                }
            </select>
            <input class="form-control stylish-input mt-2" @bind="newBudget.Category" placeholder="Or type category..." />
        </div>

        <!-- Limit -->
        <div class="col-md-3">
            <input type="number" class="form-control stylish-input" @bind="newBudget.Limit" placeholder="Limit (€)" />
        </div>

        <!-- Date Created -->
        <div class="col-md-3">
            <input type="date" class="form-control stylish-input" @bind="newBudget.DateCreated" />
        </div>

        <!-- Add Button -->
        <div class="col-md-2">
            <button class="btn btn-gradient w-100" @onclick="AddBudget">➕ Add Budget</button>
        </div>
    </div>
</div>

<!-- Budget Cards -->
<div class="row">
    @foreach (var budget in budgets)
    {
        var spent = ExpenseService.GetCategoryTotal(budget.Category, currentUser);
        var left = budget.Limit - spent;
        var percent = budget.Limit > 0 ? (int)((spent / budget.Limit) * 100) : 0;

        <div class="col-md-4">
            <div class="glass-card p-3 mb-4">
                <h5>@budget.Category</h5>
                <p>Limit: <strong>@budget.Limit €</strong></p>
                <p>Spent: <strong>@spent €</strong></p>
                <p>Left: <strong>@left €</strong></p>
                <p>Created: <strong>@budget.DateCreated.ToShortDateString()</strong></p>

                <div class="progress stylish-progress">
                    <div class="progress-bar" role="progressbar"
                         style="width:@percent%; background: linear-gradient(90deg, #4facfe, #00f2fe); border-radius: 8px;"
                         aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">
                        @percent%
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-sm btn-outline-warning rounded-circle" @onclick="() => EditBudget(budget)">✏️</button>
                    <button class="btn btn-sm btn-outline-danger rounded-circle" @onclick="() => DeleteBudget(budget.Id)">🗑️</button>
                </div>
            </div>
        </div>
    }
</div>

@if (editingBudget != null)
{
    <div class="glass-card p-4 mb-4">
        <h5 class="section-title">Edit Budget</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control stylish-input" @bind="editingBudget.Category" readonly />
            </div>
            <div class="col-md-3">
                <input type="number" class="form-control stylish-input" @bind="editingBudget.Limit" placeholder="Limit (€)" />
            </div>
            <div class="col-md-3">
                <input type="date" class="form-control stylish-input" @bind="editingBudget.DateCreated" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-gradient w-100" @onclick="SaveBudget">💾 Save</button>
                <button class="btn btn-secondary w-100" @onclick="CancelEdit">✖ Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Budget> budgets = new();
    private List<Category> categories = new();
    private Budget newBudget = new();
    private Budget? editingBudget;
    private ClaimsPrincipal? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User;

        budgets = BudgetService.GetBudgets(currentUser);
        categories = CategoryService.GetCategories();
    }

    private void AddBudget()
    {
        if (currentUser == null) return;

        if (!string.IsNullOrEmpty(newBudget.Category) && newBudget.Limit > 0)
        {
            if (newBudget.DateCreated == default)
                newBudget.DateCreated = DateTime.Now;

            BudgetService.AddBudget(newBudget, currentUser);
            newBudget = new Budget();
            budgets = BudgetService.GetBudgets(currentUser);
        }
    }

    private void EditBudget(Budget budget)
    {
        editingBudget = new Budget
        {
            Id = budget.Id,
            Category = budget.Category,
            Limit = budget.Limit,
            DateCreated = budget.DateCreated
        };
    }

    private void SaveBudget()
    {
        if (editingBudget != null && currentUser != null)
        {
            BudgetService.UpdateBudget(editingBudget, currentUser);
            editingBudget = null;
            budgets = BudgetService.GetBudgets(currentUser);
        }
    }

    private void CancelEdit()
    {
        editingBudget = null;
    }

    private void DeleteBudget(int id)
    {
        if (currentUser == null) return;

        BudgetService.DeleteBudget(id, currentUser);
        budgets = BudgetService.GetBudgets(currentUser);
    }
}
